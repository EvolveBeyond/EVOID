{
  "$schema": "https://mimocode.dev/config.json",
  "project": {
    "name": "evoid",
    "version": "0.2.3_Beta",
    "description": "Evolutionary Intent-Oriented Lightweight Distribution"
  },
  "references": {
    "evoid-docs": {
      "path": "./",
      "description": "EVOID framework source code and documentation"
    },
    "fastapi": {
      "url": "https://fastapi.tiangolo.com/",
      "description": "FastAPI web framework documentation"
    },
    "pydantic": {
      "url": "https://docs.pydantic.dev/",
      "description": "Pydantic data validation documentation"
    }
  },
  "agents": {
    "build": {
      "description": "Full-access agent for development work",
      "model": "default"
    },
    "plan": {
      "description": "Read-only agent for analysis and exploration",
      "model": "default"
    }
  },
  "permissions": {
    "edit": "ask",
    "bash": "ask"
  }
}
